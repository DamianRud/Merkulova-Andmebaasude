--SELECT Kuvab ainult 2 veergu tabelist
SELECT tootja,telefonMudel AS mudel FROM telefon;
 --Sorteerimine
 --ASC kasvavas järjekorras
 SELECT tootja,telefonMudel AS mudel,hind
 FROM telefon
 ORDER BY hind;
 --DESC kahanevas järjekorras
SELECT tootja,telefonMudel AS mudel,hind
 FROM telefon
 ORDER BY hind DESC;

 --võrdlemine >,<,=,>=,<=
 SELECT telefonMudel,hind
 From telefon
 WHERE hind >25 --leiab mudelid hinnaga suumer kui 25
 ORDER by hind;
 --Leia mudelid vahemikus 10-15 euro
SELECT telefonMudel,hind
From telefon
WHERE hind BETWEEN 10 and 15 
ORDER by hind;
--sama päring ilma between
SELECT telefonMudel,hind
From telefon
WHERE hind >=10 or hind <=25 
ORDER by hind;

--distinct ?! näitab ainult üks kordus 
SELECT DISTINCT Osystem FROM telefon;

--Võrdlumine tekstiga LIKE
SELECT tootja,telefonMudel
FROM telefon
WHERE tootja LIKE 'Sony';
--IN kuvab vastavus loetulus -соответствие перечеслению
SELECT tootja,telefonMudel
FROM telefon
WHERE tootja IN ('Sony','Samsung','Apple');

--sama päring ilma IN
SELECT tootja,telefonMudel
FROM telefon
WHERE tootja LIKE 'Sony' OR tootja LIKE 'Samsung' OR tootja LIKE'Apple';
--leia mudelid mis algavad s tähega
--% tähendab üks kõik kui palju sümboolit 
SELECT tootja,telefonMudel
FROM telefon
WHERE telefonMudel LIKE 'S%';
--sisaldab s täht '%s%'

--agregaat-funktsioonid AVG,MAX,MIN,SUM,COUNT:
--keskmine väljastamise aasta
SELECT AVG(v_aastane) AS 'keskmine Aasta'
FROM telefon;

--telefonide üldkogus
SELECT Count(*) AS 'üldkogus'
FROM telefon;
--keeruline variant funktsiooniga
--telefonide üldkogus iga tootja kohta
SELECT tootja,Count(*) AS 'üldkogus'
FROM telefon
GROUP by tootja;
--top 6
SELECT TOP 6 tootja
FROM telefon
ORDER BY tootja DESC
