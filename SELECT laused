CREATE DATABASE Rud;
use Rud;

CREATE TABLE telefon (
telefonID INT PRIMARY KEY,
tootja VARCHAR(50)not null,
telefonMudel VARCHAR(50),
hind money,
v_aastane int,
Osystem VARCHAR(50)
);


